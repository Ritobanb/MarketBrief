{
  "name": "morning-ledger",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/integration/**",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:admin": "tsx scripts/seed-admin.ts",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:import:sqlite": "tsx scripts/import-sqlite-catalogue.ts",
    "instruments:refresh": "tsx scripts/refresh-instruments.ts",
    "briefs:run": "tsx scripts/run-brief-cycle.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@playwright/test": "1.55.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "3.2.4",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
